{
  "name": "themerrdb",
  "version": "0.0.0",
  "description": "Database for movie, TV show, and game theme songs",
  "scripts": {
    "test": "npm-run-all test:unit test:report test:lint",
    "test:unit": "jest --coverage",
    "test:report": "jest --reporters=jest-junit",
    "test:lint": "eslint gh-pages-template/assets/js/*.js src/**/*.js tests/**/*.js",
    "lint": "eslint gh-pages-template/assets/js/*.js src/**/*.js tests/**/*.js",
    "lint:fix": "eslint gh-pages-template/assets/js/*.js src/**/*.js tests/**/*.js --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "gh-pages-template/assets/js/*.js",
      "src/github-scripts/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.venv/"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html",
      "json"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.4.1",
    "babel-jest": "30.4.1",
    "eslint": "10.4.1",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-junit": "17.0.0",
    "npm-run-all2": "9.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LizardByte/ThemerrDB"
  }
}
